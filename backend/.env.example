# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated origins allowed by CORS (Mini App URL)
CORS_ORIGINS=https://app.example.com

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://skydefence:skydefence@localhost:5432/skydefence?schema=public

# ── Telegram ─────────────────────────────────────────────────────
# Bot token from @BotFather. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=123456:replace-me
# Max age of initData in seconds (default 24h)
TELEGRAM_INITDATA_TTL=86400

# ── YooKassa ─────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_replace-me
# Where the user lands after payment (Mini App URL)
YOOKASSA_RETURN_URL=https://app.example.com/#/order
# Set to false ONLY for local testing without IP checks
YOOKASSA_WEBHOOK_IP_CHECK=true
