# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated origins allowed by CORS (Mini App URL)
CORS_ORIGINS=https://app.example.com

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://skydefence:skydefence@localhost:5432/skydefence?schema=public

# ── Telegram ─────────────────────────────────────────────────────
# Bot token from @BotFather. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=123456:replace-me
# Max age of initData in seconds (default 24h)
TELEGRAM_INITDATA_TTL=86400
# Chat id where the bot sends new order requests (manager's chat/group)
TELEGRAM_MANAGER_CHAT_ID=000000000
# Shared secret between API and bot for admin status-update buttons (random string)
ADMIN_API_SECRET=replace-with-random-secret
