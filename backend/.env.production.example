# Copy to .env.production on the server. NEVER commit real values.
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://app.example.com

# DATABASE_URL is injected by docker-compose.prod.yml

TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_INITDATA_TTL=86400

YOOKASSA_SHOP_ID=replace
YOOKASSA_SECRET_KEY=replace
YOOKASSA_RETURN_URL=https://app.example.com/#/order
YOOKASSA_WEBHOOK_IP_CHECK=true
